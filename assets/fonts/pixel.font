font: "/assets/fonts/pixel_operator/PixelOperator.ttf"
material: "/builtins/fonts/font.material"
size: 32
antialias: 0
alpha: 1.0
outline_alpha: 0.0
outline_width: 0.0
shadow_alpha: 0.0
shadow_blur: 0
shadow_x: 0.0
shadow_y: 0.0
output_format: TYPE_BITMAP
characters: " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
