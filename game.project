[bootstrap]
main_collection = /main/bootstrap/bootstrap.collectionc

[input]
game_binding = /input/game.input_bindingc

[script]
shared_state = 1

[display]
width = 960
height = 640
high_dpi = 1

[android]
input_method = HiddenInputField

[physics]
gravity_y = -1000.0
scale = 0.01

[html5]
scale_mode = stretch

[project]
title = Garbage Rebellion

[graphics]
default_texture_min_filter = nearest
default_texture_mag_filter = nearest
