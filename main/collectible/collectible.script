local aabb = require "main.collision.aabb"

local HALF           = vmath.vector3(8, 8, 0)
local COLOR          = vmath.vector4(1.0, 0.85, 0.0, 1.0)
local PICKUP_RADIUS_SQ = 20 * 20

function update(self, dt)
	local pos = go.get_position()
	aabb.draw_box(pos, HALF, COLOR)

	local pp = go.get_position(msg.url("main:/player"))
	local dx = pos.x - pp.x
	local dy = pos.y - pp.y
	if dx * dx + dy * dy < PICKUP_RADIUS_SQ then
		go.delete()
	end
end
