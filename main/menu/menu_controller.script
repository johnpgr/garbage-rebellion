function init(self)
	msg.post(".", "acquire_input_focus")
end

local function start_game()
	msg.post("bootstrap:/controller#controller", "show_game")
end

function on_input(self, action_id, action)
	if not action.pressed then
		return
	end

	if action_id == hash("jump") or action_id == hash("attack") or action_id == hash("touch") then
		start_game()
	end
end
